# AraBridge Environment Variables
# Copy this file to .env and fill in your values

# DeepSeek API Key (for chatbot and model evaluation)
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Neon PostgreSQL Database URL (for benchmark storage)
# Get yours at: https://neon.tech/
# Format: postgresql://username:password@hostname/database?sslmode=require
DATABASE_URL=postgresql://user:password@hostname/database?sslmode=require

# AraBridge API URL (used by Streamlit frontend)
# Default: http://localhost:8000
ARABRIDGE_API_URL=http://localhost:8000

# Hugging Face cache directory (optional)
# Default: ~/.cache/huggingface
# HF_HOME=/path/to/cache
